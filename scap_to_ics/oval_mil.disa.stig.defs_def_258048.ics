# oval:mil.disa.stig.defs:def:258048
DEF
    CRI AND
        CTN password
            TEST all_exist all
            OBJECT
                username "pattern match" ".*"
            OBJECT_END
            STATE "Valid Local GIDs"
                group_id int VAR var_25804800
            STATE_END
        CTN_END
    CRI_END
DEF_END