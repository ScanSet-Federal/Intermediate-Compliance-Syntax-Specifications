# oval:mil.disa.stig.windows2022:def:254366
DEF
    CRI AND
        CRI AND
            CTN registry
                TEST at_least_one_exists all
                OBJECT
                    hive string "HKEY_LOCAL_MACHINE"
                    key string "Software\\Policies\\Microsoft\\Windows NT\\Terminal Services"
                    name string "fDisableCdm"
                OBJECT_END
                STATE "Compliance check condition"
                    type reg_dword
                    value int 1
                STATE_END
            CTN_END
        CRI_END
    CRI_END
DEF_END