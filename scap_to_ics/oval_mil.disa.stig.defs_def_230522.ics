# oval:mil.disa.stig.defs:def:230522
DEF
    CRI AND
        CTN partition
            TEST at_least_one_exists all
            OBJECT
                mount_point "/var/tmp"
            OBJECT_END
            STATE "Compliance check condition"
                mount_options noexec
            STATE_END
        CTN_END
    CRI_END
DEF_END