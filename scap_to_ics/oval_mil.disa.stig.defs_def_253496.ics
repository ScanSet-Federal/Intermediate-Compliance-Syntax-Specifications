# oval:mil.disa.stig.defs:def:253496
DEF
    CRI AND
        CTN userright
            TEST at_least_one_exists all
            OBJECT
                userright "SE_ENABLE_DELEGATION_NAME"
            OBJECT_END
            STATE "Compliance check condition"
                # State content will be evaluated at runtime
            STATE_END
        CTN_END
    CRI_END
DEF_END