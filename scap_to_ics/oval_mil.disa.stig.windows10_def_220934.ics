# oval:mil.disa.stig.windows10:def:220934
DEF
    CRI AND
        CRI AND
            CTN registry
                TEST at_least_one_exists all
                OBJECT
                    hive "HKEY_LOCAL_MACHINE"
                    key "SYSTEM\\CurrentControlSet\\Control\\LSA\\MSV1_0"
                    name "allownullsessionfallback"
                OBJECT_END
                STATE "Compliance check condition"
                    type reg_dword
                    value int 0
                STATE_END
            CTN_END
        CRI_END
    CRI_END
DEF_END