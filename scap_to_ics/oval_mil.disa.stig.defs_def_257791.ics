# oval:mil.disa.stig.defs:def:257791
DEF
    CRI AND
        CTN file
            TEST at_least_one_exists all
            OBJECT
                filepath "/boot/grub2/grub.cfg"
            OBJECT_END
            STATE "owned by root"
                user_id int 0
            STATE_END
        CTN_END
    CRI_END
DEF_END