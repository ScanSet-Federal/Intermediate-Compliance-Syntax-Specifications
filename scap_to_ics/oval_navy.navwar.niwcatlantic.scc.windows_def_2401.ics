DEF
    CRI AND
        CTN passwordpolicy
            TEST at_least_one_exists all
            OBJECT
                # Empty object - no content elements
            OBJECT_END
            STATE "This passwordpolicy_state represents a password policy that has a anonymous_name_lookup equal to '0'."
                anonymous_name_lookup boolean 0
            STATE_END
        CTN_END
    CRI_END
DEF_END