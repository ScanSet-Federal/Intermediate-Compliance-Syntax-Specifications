# oval:mil.disa.stig.defs:def:238329
DEF
    CRI AND
        CTN shadow
            TEST at_least_one_exists all
            OBJECT
                username "root"
            OBJECT_END
            STATE "Compliance check condition"
                password "pattern match" "^!"
            STATE_END
        CTN_END
    CRI_END
DEF_END