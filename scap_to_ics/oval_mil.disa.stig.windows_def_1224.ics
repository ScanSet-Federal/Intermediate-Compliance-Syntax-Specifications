# oval:mil.disa.stig.windows:def:1224
DEF
    CRI AND
        CTN registry
            TEST at_least_one_exists all
            OBJECT
                hive string "HKEY_LOCAL_MACHINE"
                key string "SYSTEM\\CurrentControlSet\\Control\\Session Manager"
                name string "ProtectionMode"
            OBJECT_END
            STATE "Reg_Dword type and value equals 1"
                type reg_dword
                value int equals "1"
            STATE_END
        CTN_END
    CRI_END
DEF_END