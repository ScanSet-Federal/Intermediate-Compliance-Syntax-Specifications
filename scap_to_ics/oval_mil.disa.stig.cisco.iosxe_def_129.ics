# oval:mil.disa.stig.cisco.iosxe:def:129
DEF
    CRI AND
        CTN variable
            TEST at_least_one_exists all
            OBJECT
                var_ref "oval:mil.disa.stig.cisco.iosxe:var:12900"
            OBJECT_END
            STATE "Compliance check condition"
                value int "greater than or equal" "2"
            STATE_END
        CTN_END
    CRI_END
DEF_END