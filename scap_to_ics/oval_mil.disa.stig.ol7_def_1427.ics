# oval:mil.disa.stig.ol7:def:1427
DEF
    CRI AND
        CTN uname
            TEST at_least_one_exists all
            OBJECT
                # Empty object - no content elements
            OBJECT_END
            STATE "64 bit architecture"
                processor_type equals "x86_64"
            STATE_END
        CTN_END
    CRI_END
DEF_END