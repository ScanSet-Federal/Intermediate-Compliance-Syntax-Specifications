DEF
    CRI OR
        CTN rpminfo
            TEST at_least_one_exists all
            OBJECT
                name "screen"
            OBJECT_END
        CTN_END
        CTN rpminfo
            TEST at_least_one_exists all
            OBJECT
                name "tmux"
            OBJECT_END
        CTN_END
    CRI_END
DEF_END