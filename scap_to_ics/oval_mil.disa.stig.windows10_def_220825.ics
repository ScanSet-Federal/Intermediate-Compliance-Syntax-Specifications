# oval:mil.disa.stig.windows10:def:220825
DEF
    CRI AND
        CRI AND
            CTN registry
                TEST at_least_one_exists all
                OBJECT
                    hive string "HKEY_LOCAL_MACHINE"
                    key string "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System"
                    name string "MSAOptional"
                OBJECT_END
                STATE "Compliance check condition"
                    type reg_dword
                    value int 1
                STATE_END
            CTN_END
        CRI_END
    CRI_END
DEF_END