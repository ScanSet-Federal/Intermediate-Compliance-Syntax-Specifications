# oval:mil.disa.stig.windows11:def:253305
DEF
    CRI AND
        CRI AND
            CTN passwordpolicy
                TEST at_least_one_exists all
                OBJECT
                    # Empty object - no content elements
                OBJECT_END
                STATE "Compliance check condition"
                    reversible_encryption boolean 0
                STATE_END
            CTN_END
        CRI_END
    CRI_END
DEF_END