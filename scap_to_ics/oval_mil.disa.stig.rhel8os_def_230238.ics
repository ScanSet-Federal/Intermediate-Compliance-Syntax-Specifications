# oval:mil.disa.stig.rhel8os:def:230238
DEF
    CRI AND
        CRI AND
            CTN file
                TEST none_exist all
                OBJECT
                    path string "/etc"
                    filename string "pattern match" "\\.keytab$"
                OBJECT_END
            CTN_END
        CRI_END
    CRI_END
DEF_END