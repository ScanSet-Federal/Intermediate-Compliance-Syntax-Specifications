# oval:mil.disa.stig.rhel9os:def:257914
DEF
    CRI AND
        CRI AND
            CTN file
                TEST at_least_one_exists all
                OBJECT
                    path "/var/log"
                    filename nil
                OBJECT_END
                STATE "owned by root"
                    user_id int 0
                STATE_END
            CTN_END
        CRI_END
    CRI_END
DEF_END