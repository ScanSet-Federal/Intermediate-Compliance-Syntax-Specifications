# oval:mil.disa.stig.firefox.windows:def:118
DEF
    CRI AND
        CTN registry
            TEST at_least_one_exists all
            OBJECT
                hive string "HKEY_LOCAL_MACHINE"
                key string "SOFTWARE\\Policies\\Mozilla\\Firefox"
                name string "DisablePrivateBrowsing"
            OBJECT_END
            STATE "Compliance check condition"
                type reg_dword
                value int 1
            STATE_END
        CTN_END
    CRI_END
DEF_END