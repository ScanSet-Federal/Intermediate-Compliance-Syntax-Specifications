# oval:mil.disa.stig.defs:def:238341
DEF
    CRI AND
        CTN file
            TEST at_least_one_exists all
            OBJECT
                filepath "/var/log/syslog"
            OBJECT_END
            STATE "Group-owned by adm"
                group_id int VAR var_23834100
            STATE_END
        CTN_END
    CRI_END
DEF_END