# oval:mil.disa.stig.defs:def:254423
DEF
    CRI AND
        CTN userright
            TEST at_least_one_exists "at least one"
            OBJECT
                userright "SE_DENY_SERVICE_LOGON_NAME"
            OBJECT_END
            STATE "Compliance check condition"
                # State content will be evaluated at runtime
            STATE_END
        CTN_END
    CRI_END
DEF_END