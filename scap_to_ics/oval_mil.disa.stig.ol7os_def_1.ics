# oval:mil.disa.stig.ol7os:def:1
DEF
    CRI AND
        CTN rpminfo
            TEST all_exist all
            OBJECT
                name "oraclelinux-release"
            OBJECT_END
            STATE "Compliance check condition"
                version "pattern match" "^7\\.\\d+$"
            STATE_END
        CTN_END
    CRI_END
DEF_END