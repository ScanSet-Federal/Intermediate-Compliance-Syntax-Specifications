# oval:mil.disa.stig.ol8os:def:248556
DEF
    CRI AND
        CRI AND
            CTN file
                TEST at_least_one_exists all
                OBJECT
                    filepath "/var/log/messages"
                OBJECT_END
                STATE "group-owned by root"
                    group_id int 0
                STATE_END
            CTN_END
        CRI_END
    CRI_END
DEF_END