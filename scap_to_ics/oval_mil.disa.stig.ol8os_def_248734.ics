DEF
    VAR var_23039700 string ""
    CRI AND
        CRI AND
            CTN file
                TEST at_least_one_exists all
                OBJECT
                    filepath VAR var_23039700
                OBJECT_END
                STATE "group-owned by root"
                    group_id int 0
                STATE_END
            CTN_END
        CRI_END
    CRI_END
DEF_END