# oval:mil.disa.stig.ol7:def:1428
DEF
    CRI OR
        CTN uname
            TEST at_least_one_exists all
            OBJECT
                # Empty object - no content elements
            OBJECT_END
            STATE "64 bit architecture"
                processor_type equals "ppc64"
            STATE_END
        CTN_END
        CTN uname
            TEST at_least_one_exists all
            OBJECT
                # Empty object - no content elements
            OBJECT_END
            STATE "64 bit architecture"
                processor_type equals "ppc64le"
            STATE_END
        CTN_END
    CRI_END
DEF_END