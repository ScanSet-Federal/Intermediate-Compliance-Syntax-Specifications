# oval:mil.disa.stig.ol8os:def:248597
DEF
    CRI AND
        CRI AND
            CTN file
                TEST none_exist all
                OBJECT
                    BEHAVIOR recurse_down_local_d -1
                    path "/"
                    filename "shosts.equiv"
                OBJECT_END
            CTN_END
        CRI_END
    CRI_END
DEF_END