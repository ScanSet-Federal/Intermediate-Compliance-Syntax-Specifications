# oval:mil.disa.stig.defs:def:258236
DEF
    CRI AND
        CTN symlink
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/crypto-policies/back-ends/bind.config"
            OBJECT_END
            STATE "bind"
                canonical_path /usr/share/crypto-policies/FIPS/bind.txt
            STATE_END
        CTN_END
        CTN symlink
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/crypto-policies/back-ends/gnutls.config"
            OBJECT_END
            STATE "gnutls"
                canonical_path /usr/share/crypto-policies/FIPS/gnutls.txt
            STATE_END
        CTN_END
        CTN symlink
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/crypto-policies/back-ends/java.config"
            OBJECT_END
            STATE "java"
                canonical_path /usr/share/crypto-policies/FIPS/java.txt
            STATE_END
        CTN_END
        CTN symlink
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/crypto-policies/back-ends/javasystem.config"
            OBJECT_END
            STATE "javasystem"
                canonical_path /usr/share/crypto-policies/FIPS/javasystem.txt
            STATE_END
        CTN_END
        CTN symlink
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/crypto-policies/back-ends/krb5.config"
            OBJECT_END
            STATE "krb5"
                canonical_path /usr/share/crypto-policies/FIPS/krb5.txt
            STATE_END
        CTN_END
        CTN symlink
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/crypto-policies/back-ends/libreswan.config"
            OBJECT_END
            STATE "libreswan"
                canonical_path /usr/share/crypto-policies/FIPS/libreswan.txt
            STATE_END
        CTN_END
        CTN symlink
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/crypto-policies/back-ends/libssh.config"
            OBJECT_END
            STATE "libssh"
                canonical_path /usr/share/crypto-policies/FIPS/libssh.txt
            STATE_END
        CTN_END
        CTN symlink
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/crypto-policies/back-ends/nss.config"
            OBJECT_END
            STATE "nss"
                canonical_path /usr/share/crypto-policies/FIPS/nss.txt
            STATE_END
        CTN_END
        CTN symlink
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/crypto-policies/back-ends/openssh.config"
            OBJECT_END
            STATE "openssh"
                canonical_path /usr/share/crypto-policies/FIPS/openssh.txt
            STATE_END
        CTN_END
        CTN symlink
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/crypto-policies/back-ends/opensshserver.config"
            OBJECT_END
            STATE "opensshserver"
                canonical_path /usr/share/crypto-policies/FIPS/opensshserver.txt
            STATE_END
        CTN_END
        CTN symlink
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/crypto-policies/back-ends/opensslcnf.config"
            OBJECT_END
            STATE "opensslcnf"
                canonical_path /usr/share/crypto-policies/FIPS/opensslcnf.txt
            STATE_END
        CTN_END
        CTN symlink
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/crypto-policies/back-ends/openssl.config"
            OBJECT_END
            STATE "openssl"
                canonical_path /usr/share/crypto-policies/FIPS/openssl.txt
            STATE_END
        CTN_END
    CRI_END
DEF_END