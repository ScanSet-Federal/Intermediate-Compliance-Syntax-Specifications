DEF
    CRI AND
        CTN textfilecontent54
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/audit/audit.rules"
                pattern "pattern match" "^\\s*-a\\s+(always,exit|exit,always)\\s+-F\\s+arch=b32\\s+(.*(-S\\s+unlink\\s+|(\\s+|,)unlink(\\s+|,))).*-F\\s+auid>=1000\\s+-F\\s+auid!=(4294967295|-1|unset)(\\s+(-k\\s+|-F\\s+key=)[-\\w]+)*\\s*$"
                instance int "greater than or equal" "1"
            OBJECT_END
        CTN_END
