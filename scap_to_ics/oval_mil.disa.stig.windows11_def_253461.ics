# oval:mil.disa.stig.windows11:def:253461
DEF
    CRI AND
        CRI AND
            CTN registry
                TEST at_least_one_exists all
                OBJECT
                    hive string "HKEY_LOCAL_MACHINE"
                    key string "System\\CurrentControlSet\\Control\\Lsa"
                    name string "case insensitive equals" "NoLMHash"
                OBJECT_END
                STATE "Compliance check condition"
                    type reg_dword
                    value int 1
                STATE_END
            CTN_END
        CRI_END
    CRI_END
DEF_END