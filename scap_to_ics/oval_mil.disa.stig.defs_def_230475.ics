# oval:mil.disa.stig.defs:def:230475
DEF
    CRI AND
        CTN textfilecontent54
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/aide.conf"
                pattern "pattern match" "^\\s*/usr/sbin/auditctl\\s+\\S+"
                instance int "greater than or equal" "1"
            OBJECT_END
        CTN_END
        CTN textfilecontent54
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/aide.conf"
                pattern "pattern match" "^\\s*/usr/sbin/auditd\\s+\\S+"
                instance int "greater than or equal" "1"
            OBJECT_END
        CTN_END
        CTN textfilecontent54
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/aide.conf"
                pattern "pattern match" "^\\s*/usr/sbin/ausearch\\s+\\S+"
                instance int "greater than or equal" "1"
            OBJECT_END
        CTN_END
        CTN textfilecontent54
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/aide.conf"
                pattern "pattern match" "^\\s*/usr/sbin/aureport\\s+\\S+"
                instance int "greater than or equal" "1"
            OBJECT_END
        CTN_END
        CTN textfilecontent54
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/aide.conf"
                pattern "pattern match" "^\\s*/usr/sbin/autrace\\s+\\S+"
                instance int "greater than or equal" "1"
            OBJECT_END
        CTN_END
        CTN textfilecontent54
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/aide.conf"
                pattern "pattern match" "^\\s*/usr/sbin/augenrules\\s+\\S+"
                instance int "greater than or equal" "1"
            OBJECT_END
        CTN_END
    CRI_END
DEF_END