# oval:navy.navwar.niwcatlantic.scc.windows2022:def:1301
DEF
    CRI AND
        CTN registry
            TEST at_least_one_exists "only one"
            OBJECT
                hive "HKEY_LOCAL_MACHINE"
                key "System\\CurrentControlSet\\Control\\SecureBoot\\State"
                name nil
            OBJECT_END
        CTN_END
    CRI_END
DEF_END