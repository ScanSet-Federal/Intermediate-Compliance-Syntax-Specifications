# oval:mil.disa.stig.defs:def:248706
DEF
    CRI AND
        CTN file
            TEST at_least_one_exists all
            OBJECT
                filepath "/usr/bin/lastlog"
            OBJECT_END
            STATE "owned by root"
                user_id int 0
            STATE_END
        CTN_END
    CRI_END
DEF_END