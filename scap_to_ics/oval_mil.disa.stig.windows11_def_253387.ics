# oval:mil.disa.stig.windows11:def:253387
DEF
    CRI AND
        CRI AND
            CTN registry
                TEST at_least_one_exists all
                OBJECT
                    hive string "HKEY_LOCAL_MACHINE"
                    key string "Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer"
                    name string "NoAutorun"
                OBJECT_END
                STATE "Compliance check condition"
                    type reg_dword
                    value int 1
                STATE_END
            CTN_END
        CRI_END
    CRI_END
DEF_END