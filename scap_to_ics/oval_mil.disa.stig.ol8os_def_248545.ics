# oval:mil.disa.stig.ol8os:def:248545
DEF
    CRI AND
        CRI AND
            CTN file
                TEST none_exist all
                OBJECT
                    path string "/etc"
                    filename string "pattern match" "\\.keytab$"
                OBJECT_END
            CTN_END
        CRI_END
    CRI_END
DEF_END