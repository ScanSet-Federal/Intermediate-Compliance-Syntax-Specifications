# oval:mil.disa.stig.windows2022:def:254492
DEF
    CRI AND
        CRI AND
            CTN userright
                TEST at_least_one_exists all
                OBJECT
                    userright "SE_TCB_NAME"
                OBJECT_END
                STATE "Compliance check condition"
                    # State content will be evaluated at runtime
                STATE_END
            CTN_END
        CRI_END
    CRI_END
DEF_END