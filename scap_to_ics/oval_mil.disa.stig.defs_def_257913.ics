# oval:mil.disa.stig.defs:def:257913
DEF
    CRI AND
        CTN file
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/shadow-"
            OBJECT_END
            STATE "group-owned by root"
                group_id int 0
            STATE_END
        CTN_END
    CRI_END
DEF_END