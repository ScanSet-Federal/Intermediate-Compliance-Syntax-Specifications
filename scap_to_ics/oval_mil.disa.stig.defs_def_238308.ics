# oval:mil.disa.stig.defs:def:238308
DEF
    CRI AND
        CTN symlink
            TEST at_least_one_exists all
            OBJECT
                filepath "/etc/localtime"
            OBJECT_END
            STATE "Compliance check condition"
                canonical_path /usr/share/zoneinfo/Etc/UTC
            STATE_END
        CTN_END
    CRI_END
DEF_END