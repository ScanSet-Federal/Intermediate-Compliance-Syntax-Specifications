# oval:mil.disa.stig.ubuntu2204os:def:260586
DEF
    CRI AND
        CRI AND
            CTN textfilecontent54
                TEST at_least_one_exists all
                OBJECT
                    filepath "/etc/aide.conf"
                    pattern "pattern match" "^\\s*/sbin/auditctl\\s+\\S+"
                    instance int "greater than or equal" "1"
                OBJECT_END
            CTN_END
            CTN textfilecontent54
                TEST at_least_one_exists all
                OBJECT
                    filepath "/etc/aide.conf"
                    pattern "pattern match" "^\\s*/sbin/auditd\\s+\\S+"
                    instance int "greater than or equal" "1"
                OBJECT_END
            CTN_END
            CTN textfilecontent54
                TEST at_least_one_exists all
                OBJECT
                    filepath "/etc/aide.conf"
                    pattern "pattern match" "^\\s*/sbin/ausearch\\s+\\S+"
                    instance int "greater than or equal" "1"
                OBJECT_END
            CTN_END
            CTN textfilecontent54
                TEST at_least_one_exists all
                OBJECT
                    filepath "/etc/aide.conf"
                    pattern "pattern match" "^\\s*/sbin/aureport\\s+\\S+"
                    instance int "greater than or equal" "1"
                OBJECT_END
            CTN_END
            CTN textfilecontent54
                TEST at_least_one_exists all
                OBJECT
                    filepath "/etc/aide.conf"
                    pattern "pattern match" "^\\s*/sbin/autrace\\s+\\S+"
                    instance int "greater than or equal" "1"
                OBJECT_END
            CTN_END
            CTN textfilecontent54
                TEST at_least_one_exists all
                OBJECT
                    filepath "/etc/aide.conf"
                    pattern "pattern match" "^\\s*/sbin/augenrules\\s+\\S+"
                    instance int "greater than or equal" "1"
                OBJECT_END
            CTN_END
        CRI_END
    CRI_END
DEF_END