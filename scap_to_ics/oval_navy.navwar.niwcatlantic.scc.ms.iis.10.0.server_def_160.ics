# oval:navy.navwar.niwcatlantic.scc.ms.iis.10.0.server:def:160
DEF
    CRI AND
        CTN registry
            TEST none_exist all
            OBJECT
                hive "HKEY_LOCAL_MACHINE"
                key "Software\\Microsoft\\InetStp\\Components"
                name "WebDAV"
            OBJECT_END
        CTN_END
    CRI_END
DEF_END