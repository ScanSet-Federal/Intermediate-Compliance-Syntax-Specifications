# oval:mil.disa.stig.rhel9os:def:257955
DEF
    CRI AND
        CRI AND
            CTN file
                TEST none_exist all
                OBJECT
                    BEHAVIOR recurse_down_local_d -1
                    path "/"
                    filename "shosts.equiv"
                OBJECT_END
            CTN_END
        CRI_END
    CRI_END
DEF_END