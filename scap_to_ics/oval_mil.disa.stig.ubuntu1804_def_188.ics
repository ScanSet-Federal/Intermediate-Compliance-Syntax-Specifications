# oval:mil.disa.stig.ubuntu1804:def:188
DEF
    CRI AND
        CRI AND
            CRI AND
                CTN dpkginfo
                    TEST all_exist all
                    OBJECT
                        name "auditd"
                    OBJECT_END
                CTN_END
            CRI_END
            CTN process58
                TEST at_least_one_exists all
                OBJECT
                    command_line string "pattern match" "^\\/sbin\\/auditd\\b"
                    pid int "greater than" "1"
                OBJECT_END
            CTN_END
        CRI_END
        CTN textfilecontent54
            TEST all_exist all
            OBJECT
                filepath "/etc/audit/audit.rules"
                pattern "pattern match" "^\\s*-a\\s+(always,exit|exit,always)\\s+-F\\s+arch=b32\\s+(?:.*(-S[\\s]+setxattr[\\s]+|([\\s]+|[,])setxattr([\\s]+|[,])).*)-F\\s+auid>=1000\\s+-F\\s+auid!=(unset|-1|4294967295).*(-k[\\s]+|-F[\\s]+key=)[-\\w]+[\\s]*$"
                instance int "greater than or equal" "1"
            OBJECT_END
        CTN_END
