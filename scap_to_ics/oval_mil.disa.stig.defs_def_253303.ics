# oval:mil.disa.stig.defs:def:253303
DEF
    CRI AND
        CTN passwordpolicy
            TEST at_least_one_exists all
            OBJECT
                # Empty object - no content elements
            OBJECT_END
            STATE "Minimum Password Length is greater than or equal to 14"
                min_passwd_len int "greater than or equal" "14"
            STATE_END
        CTN_END
    CRI_END
DEF_END