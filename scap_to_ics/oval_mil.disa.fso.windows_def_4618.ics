# oval:mil.disa.fso.windows:def:4618
DEF
    CRI AND
        CTN registry
            TEST at_least_one_exists all
            OBJECT
                hive string "HKEY_LOCAL_MACHINE"
                key string "System\\CurrentControlSet\\Control\\Print\\Providers\\LanMan Print Services\\Servers"
                name string "AddPrinterDrivers"
            OBJECT_END
            STATE "Reg_Dword type and value equals 1"
                type reg_dword
                value int equals "1"
            STATE_END
        CTN_END
    CRI_END
DEF_END