# oval:mil.disa.stig.sles15:def:163
DEF
    CRI AND
        CTN textfilecontent54
            TEST all_exist all
            OBJECT
                filepath "/etc/audit/audit.rules"
                pattern "pattern match" "^\\s*-a\\s+(always,exit|exit,always)\\s+-F\\s+arch=b32\\s+(.*(-S\\s+removexattr\\s+|(\\s+|,)removexattr(\\s+|,))).*-F\\s+auid>=1000\\s+-F\\s+auid!=(4294967295|-1|unset)(\\s+(-k\\s+|-F\\s+key=)[-\\w]+)*\\s*$"
                instance int "greater than or equal" "1"
            OBJECT_END
        CTN_END
