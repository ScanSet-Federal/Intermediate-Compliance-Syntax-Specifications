# oval:mil.disa.stig.linux:def:100005
DEF
    CRI OR
        CTN rpminfo
            TEST all_exist all
            OBJECT
                name "gnome-shell"
            OBJECT_END
        CTN_END
        CTN dpkginfo
            TEST all_exist all
            OBJECT
                name "gnome-shell"
            OBJECT_END
        CTN_END
    CRI_END
DEF_END