# oval:mil.disa.stig.ol7:def:271
DEF
    CRI AND
        CTN sysctl
            TEST all_exist all
            OBJECT
                name "net.ipv4.conf.default.accept_source_route"
            OBJECT_END
            STATE "Compliance check condition"
                value int 0
            STATE_END
        CTN_END
    CRI_END
DEF_END