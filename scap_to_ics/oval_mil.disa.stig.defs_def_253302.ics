# oval:mil.disa.stig.defs:def:253302
DEF
    CRI AND
        CTN passwordpolicy
            TEST at_least_one_exists all
            OBJECT
                # Empty object - no content elements
            OBJECT_END
            STATE "Compliance check condition"
                min_passwd_age int "greater than or equal" "86400"
            STATE_END
        CTN_END
    CRI_END
DEF_END