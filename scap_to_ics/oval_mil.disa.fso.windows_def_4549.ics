# oval:mil.disa.fso.windows:def:4549
DEF
    CRI OR
        CTN registry
            TEST at_least_one_exists all
            OBJECT
                hive string "HKEY_LOCAL_MACHINE"
                key string "System\\CurrentControlSet\\Services\\Netlogon\\Parameters"
                name string "SignSecureChannel"
            OBJECT_END
            STATE "Reg_Dword type and value equals variable"
                type reg_dword
                value int VAR var_454900
            STATE_END
        CTN_END
        CTN registry
            TEST at_least_one_exists all
            OBJECT
                hive string "HKEY_LOCAL_MACHINE"
                key string "System\\CurrentControlSet\\Services\\Netlogon\\Parameters"
                name string "RequireSignOrSeal"
            OBJECT_END
            STATE "Reg_Dword type and value equals 1"
                type reg_dword
                value int equals "1"
            STATE_END
        CTN_END
    CRI_END
DEF_END